{
  "name": "bb-calc-js",
  "version": "0.2.0",
  "description": "napi-rs Node bindings for the bb-calc Bloodborne Attack Rating calculator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": {
    "./index.js": "./browser.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhickey/bb-calc.git",
    "directory": "packages/bb-calc-js"
  },
  "license": "MIT",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "browser.js",
    "dist"
  ],
  "napi": {
    "binaryName": "bb-calc-js",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "wasm32-wasip1-threads"
    ]
  },
  "engines": {
    "node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "napi build --platform --release && tsc -p tsconfig.build.json",
    "build:debug": "napi build --platform && tsc -p tsconfig.build.json",
    "build:ts": "tsc -p tsconfig.build.json",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "preversion": "napi build --platform && git add .",
    "version": "napi version"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@napi-rs/wasm-runtime": "^1.1.5",
    "@oxc-node/core": "^0.1.0",
    "@tybys/wasm-util": "^0.10.0",
    "@types/node": "^22.20.0",
    "ava": "^8.0.0",
    "chalk": "^5.6.2",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.0"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  }
}
